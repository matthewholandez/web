{
  "name": "website-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:home\" \"npm run dev:blog\"",
    "dev:home": "npm run dev -w home",
    "dev:blog": "npm run dev -w blog"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
